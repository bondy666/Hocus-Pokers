# Azure SQL connection. Use a full connection string OR the discrete fields below.
SQL_CONNECTION_STRING=Server=tcp:your-server.database.windows.net,1433;Database=hocuspokers;User Id=your-user;Password=your-password;Encrypt=true;TrustServerCertificate=false;

# Port the API listens on (Azure App Service sets this automatically).
PORT=3000

# Comma-separated list of allowed CORS origins for local dev.
CORS_ORIGINS=http://localhost:5173

# --- Authentication ---
# In production, Azure App Service "Easy Auth" handles Google/Microsoft login and
# forwards the signed-in user to this server (no settings needed here).
#
# Optional allow-list: only these emails may perform writes. Empty = any signed-in user.
ADMIN_EMAILS=

# Local dev only: simulate a signed-in user (Easy Auth isn't present locally).
ALLOW_DEV_AUTH=true
DEV_USER_EMAIL=organiser@hocuspokers.local
