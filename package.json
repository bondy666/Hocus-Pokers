{
  "name": "hocus-pokers",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "Hocus Pokers — card-room themed stats tracker for a Horsham poker club",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "build:all": "npm run build && npm --prefix server install && npm --prefix server run build",
    "start": "node server/dist/index.js"
  },
  "dependencies": {
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.17.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^5.0.0",
    "typescript": "~5.9.0",
    "vite": "^7.1.0"
  }
}
